{
  "$schema": "https://mintlify.com/schema.json",
  "theme": "mint",
  "name": "Z-API Docs",
  "logo": {
    "light": "https://staging.z-api.io/logos/SVG/Ativo%2016.svg",
    "dark": "https://staging.z-api.io/logos/SVG/Ativo%2016.svg"
  },
  "favicon": "https://www.z-api.io/wp-content/themes/z-api/favicon.png",
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "poimandres",
        "light": "github-light"
      }
    }
  },
  "background": {
    "color": {
      "dark": "#14161f"
    }
  },
  "colors": {
    "primary": "#00B140",
    "light": "#00D455",
    "dark": "#007A2C"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Painel",
      "href": "https://app.z-api.io/"
    }
  },
  "api": {
    "mdx": {
      "server": "https://api.z-api.io",
      "auth": {
        "method": "key",
        "name": "Client-Token"
      }
    },
    "examples": {
      "defaults": "required"
    }
  },
  "navigation": {
