{
  "name": "zapi-central-dev",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "npx cross-env NO_UPDATE_NOTIFIER=1 NODE_ENV=development docusaurus start --port 3000 --host 0.0.0.0 --no-open",
    "start:open": "npx cross-env NO_UPDATE_NOTIFIER=1 NODE_ENV=development docusaurus start --port 3000",
    "start:fast": "npx cross-env NO_UPDATE_NOTIFIER=1 NODE_ENV=development FAST_REFRESH=true docusaurus start --port 3000 --no-open --no-minify",
    "start:watch": "npx cross-env NO_UPDATE_NOTIFIER=1 NODE_ENV=development docusaurus start --port 3000 --poll",
    "start:win": "powershell -ExecutionPolicy Bypass -File scripts/start-windows.ps1",
    "start:win-cmd": "scripts\\start-windows.cmd",
    "fix:port": "powershell -ExecutionPolicy Bypass -File scripts/fix-port-3000.ps1",
    "fix:port-cmd": "scripts\\fix-port-3000.cmd",
    "build": "npx --yes cross-env NO_UPDATE_NOTIFIER=1 NODE_ENV=production NODE_OPTIONS=--max-old-space-size=8192 docusaurus build",
    "build:dev": "npx --yes cross-env NO_UPDATE_NOTIFIER=1 NODE_ENV=development NODE_OPTIONS=--max-old-space-size=8192 docusaurus build --out-dir build-dev",
    "build:fast": "npx --yes cross-env NO_UPDATE_NOTIFIER=1 NODE_ENV=production NODE_OPTIONS=--max-old-space-size=8192 docusaurus build --minify=false",
    "build:prod": "npm run typecheck && npm run build",
    "build:win": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1",
    "build:win-cmd": "scripts\\build-windows.cmd",
    "build:clean": "npm run clear && npm run build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "serve:build": "npm run build && npm run serve",
    "clean-serve:build": "npm run clear && npm run build && npm run serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "lint": "eslint --config .eslintrc.json --ext .ts,.tsx,.js,.jsx --ignore-path .eslintignore 'src/**/*.{ts,tsx,js,jsx}' --max-warnings=1000",
    "lint:fix": "eslint --config .eslintrc.json --ext .ts,.tsx,.js,.jsx --fix --ignore-path .eslintignore src/ blog/ docs/ static/",
    "lint:css": "npx stylelint \"src/**/*.css\" --config .stylelintrc.json",
    "lint:css:fix": "npx stylelint \"src/**/*.css\" --config .stylelintrc.json --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:accessibility": "axe http://localhost:3000 --tags wcag2a,wcag2aa --reporter json --output reports/accessibility.json || true",
    "prebuild": "npm run clear",
    "postbuild": "echo Build concluído com sucesso!"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/plugin-client-redirects": "^3.9.2",
    "@docusaurus/plugin-ideal-image": "3.9.2",
    "@docusaurus/plugin-sitemap": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/theme-live-codeblock": "^3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@easyops-cn/docusaurus-search-local": "^0.52.2",
    "@formkit/auto-animate": "^0.9.0",
    "@mdx-js/react": "^3.0.0",
    "@xyflow/react": "^12.9.3",
    "clsx": "^2.0.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "katex": "^0.16.25",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.553.0",
    "lunr-languages": "^1.14.0",
    "mermaid": "^11.12.1",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-intersection-observer": "^9.16.0",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-code-titles": "^0.1.2",
    "remark-emoji": "^5.0.2",
    "remark-footnotes": "^4.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@eslint/js": "^9.16.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/aria-query": "^5.0.4",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/graceful-fs": "^4.1.9",
    "@types/jest": "^29.5.14",
    "@types/jsdom": "^27.0.0",
    "@types/react": "^19.2.2",
    "@types/semver": "^7.7.1",
    "@types/stack-utils": "^2.0.3",
    "@types/tough-cookie": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "configstore": "^6.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "identity-obj-proxy": "^3.0.0",
    "is-npm": "^6.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.6.2",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^36.0.1",
    "ts-jest": "^29.1.1",
    "typescript": "~5.9.3",
    "update-notifier": "^7.3.1",
    "xdg-basedir": "^5.1.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
